{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "zzaala",
          "appId": "1:1040493098798:android:accda5ca1db6f7eaa5acbf",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "zzaala",
          "appId": "1:1040493098798:ios:8a7132b5e5d73f5ca5acbf",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "zzaala",
          "configurations": {
            "android": "1:1040493098798:android:accda5ca1db6f7eaa5acbf",
            "ios": "1:1040493098798:ios:8a7132b5e5d73f5ca5acbf",
            "web": "1:1040493098798:web:10b5d33935ce3947a5acbf"
          }
        }
      }
    }
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint"
      ]
    }
  ]
}
